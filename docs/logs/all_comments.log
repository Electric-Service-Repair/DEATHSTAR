commands/yoda.sh:    # Select random wisdom
commands/yoda.sh:    local wisdom_idx=$((RANDOM % ${#YODA_WISDOM[@]}))
commands/yoda.sh:    # Developer-specific tips
commands/yoda.sh:    local tip_idx=$((RANDOM % ${#dev_tips[@]}))
